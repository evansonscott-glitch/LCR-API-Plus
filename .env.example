# LCR API Credentials
LCR_USERNAME=your_username_here
LCR_PASSWORD=your_password_here

# Unit Information
# Your primary unit number (Ward or Stake)
LCR_UNIT_NUMBER=your_unit_number_here
LCR_UNIT_NAME=your_unit_name_here

# Optional: Path to chromedriver if auto-install fails
# LCR_CHROME_DRIVER_PATH=/path/to/chromedriver

# Optional: JSON string for multiple units if running stake-level analytics
# Format: [{"name": "Ward 1", "number": 123}, {"name": "Ward 2", "number": 456}]
# LCR_UNITS_JSON=[]
